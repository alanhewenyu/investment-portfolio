# === Capital Mode ===
# Leave at 0 for simple cost-based capital calculation (recommended for new users).
# Set to actual deposit amounts for deposit-based tracking (advanced).
FUTU_CAPITAL=0
FUTU_DEPOSIT_FX=1.0
B_SHARE_CAPITAL=0

# Optional: custom database path
# PORTFOLIO_DB_PATH=/path/to/portfolio.db

# Optional: backup directory (default: ./backups inside project)
# Set to a cloud-synced folder for automatic off-site backup.
# BACKUP_DIR=~/Documents/backup/portfolio-tracker

# Optional: FMP API key for industry classification (yfinance used as free fallback)
# FMP_API_KEY=your_key_here

# Optional: multiple portfolios (sidebar switcher appears when 2+ configured)
# Format: PORTFOLIOS=Name1:file1.db,Name2:file2.db
# Per-portfolio capital: CAPITAL_<Name>=deposit_cap,deposit_fx,b_cap[,broker1,broker2,...]
#   - First 3 values: deposit capital (CNY), deposit FX rate, B-share capital (CNY)
#   - Optional broker names after: which brokers use deposit mode (skip in cost calc)
# PORTFOLIOS=Personal:portfolio.db,Family:portfolio_family.db
# CAPITAL_Personal=100000,7.0,0,Futu
